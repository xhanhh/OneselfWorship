# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# ===== Vercel + Supabase (Postgres) =====
# Prisma runtime + db push (pooled connection, recommended)
DATABASE_URL="${POSTGRES_PRISMA_URL}"
# Prisma migrate (direct/non-pooling connection)
DIRECT_URL="${POSTGRES_URL_NON_POOLING}"

# Optional explicit Prisma vars (already injected by Vercel Supabase integration)
POSTGRES_DATABASE=""
POSTGRES_HOST=""
POSTGRES_PASSWORD=""
POSTGRES_PRISMA_URL=""
POSTGRES_URL=""
POSTGRES_URL_NON_POOLING=""
POSTGRES_USER=""

# Supabase project keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_JWT_SECRET=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_URL=""

NUXT_PUBLIC_TURNSTILE_SITE_KEY=""
NUXT_TURNSTILE_SECRET_KEY=""
ADMIN_EMAIL="user@host.name"
